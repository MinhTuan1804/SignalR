@{
    ViewData["Title"] = "Real-time Chat";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white d-flex align-items-center rounded-top p-3">
                    <i class="bi bi-chat-dots-fill fs-4 me-2"></i>
                    <h5 class="mb-0">Phòng Chat Real-time (SignalR)</h5>
                    <span class="ms-auto badge bg-success rounded-pill d-flex align-items-center px-2 py-1">
                        <span class="spinner-grow spinner-grow-sm text-light me-1" style="width: 0.5rem; height: 0.5rem;" role="status"></span>
                        Trực tuyến
                    </span>
                </div>
                
                <div class="card-body p-0">
                    <div id="messagesList" class="chat-container">
                        <!-- Tin nhắn sẽ hiển thị ở đây -->
                        <div class="text-center text-muted mt-2 mb-4" style="font-size: 0.85rem;">
                            <small>Chào mừng bạn đến với phòng chat. Hãy nhập tên và bắt đầu trò chuyện!</small>
                        </div>
                    </div>
                </div>
                
                <div class="card-footer bg-light p-3">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <input type="text" class="form-control" id="userInput" placeholder="Tên của bạn">
                        </div>
                        <div class="col-md-7">
                            <input type="text" class="form-control" id="messageInput" placeholder="Nhập tin nhắn..." autocomplete="off">
                        </div>
                        <div class="col-md-2">
                            <button type="button" id="sendButton" class="btn btn-primary w-100 fw-bold d-flex align-items-center justify-content-center">
                                Gửi <i class="bi bi-send-fill ms-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- FontAwesome/Bootstrap Icons for better UI -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
    <!-- Tải SignalR client từ CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <!-- Script xử lý kết nối và giao diện -->
    <script src="~/js/chat.js" asp-append-version="true"></script>
}